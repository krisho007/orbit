# ==============================================
# Orbit Mobile/Web Environment Variables.
# This is git tracked. DO NOT PUT ANYTHING HERE THAT IS NOT PUBLIC.
# ==============================================
# Note: Expo requires variables to be prefixed with EXPO_PUBLIC_
# to be accessible in the app

# -----------------
# Supabase (Required)
# -----------------
# Used for authentication and database access
# Get these from: Supabase Dashboard → Settings → API

# Your Supabase project URL
EXPO_PUBLIC_SUPABASE_URL="https://ghjqmkvsnwvppbpfnoii.supabase.co"

# Supabase anonymous key (public, safe to expose in mobile apps)
EXPO_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_wyT6ebepitJ3_4k1YvC8MQ_1Va3fmJb"

# -----------------
# API URL (Set per command/profile)
# -----------------
# Keep this unset here so you don't need to edit this file repeatedly.
# Use package scripts instead:
# - bun run web:local
# - bun run android:local
# - bun run ios:local
# Preview/production EAS profiles set EXPO_PUBLIC_API_URL in apps/mobile/eas.json.
