# Keep selected Android native sources in apps/mobile under version control
!apps/mobile/android/
!apps/mobile/android/app/
!apps/mobile/android/app/src/
!apps/mobile/android/app/src/main/
!apps/mobile/android/app/src/main/AndroidManifest.xml
!apps/mobile/android/app/src/main/java/
!apps/mobile/android/app/src/main/java/com/
!apps/mobile/android/app/src/main/java/com/orbit/
!apps/mobile/android/app/src/main/java/com/orbit/app/
!apps/mobile/android/app/src/main/java/com/orbit/app/MainActivity.kt
!apps/mobile/android/app/src/main/java/com/orbit/app/PhoneStateReceiver.kt

# Keep Expo module native sources under version control
!apps/mobile/modules/**/android/
!apps/mobile/modules/**/android/src/
!apps/mobile/modules/**/android/src/main/
!apps/mobile/modules/**/android/src/main/java/
!apps/mobile/modules/**/android/src/main/java/expo/
!apps/mobile/modules/**/android/src/main/java/expo/modules/
!apps/mobile/modules/**/android/src/main/java/expo/modules/**/
!apps/mobile/modules/**/android/src/main/java/expo/modules/**/*.kt

# Allow Claude Code commands to be tracked
!.claude/
.claude/*
!.claude/commands/
