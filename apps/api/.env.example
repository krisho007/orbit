# ==============================================
# Orbit API Environment Variables
# ==============================================

# -----------------
# Database (Required)
# -----------------
# Neon Postgres connection string.
# Get this from: Neon Console → your project → Connection Details (pooled).
# Make sure the `vector` (pgvector) extension is enabled on the database.
DATABASE_URL="postgresql://<user>:<password>@<endpoint>.neon.tech/<db>?sslmode=require"

# -----------------
# Auth — Better Auth (Required)
# -----------------
# Google-only sign-in. Better Auth owns /api/auth/* and verifies sessions.

# Signing secret for sessions. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="<32+ char random secret>"

# Public base URL of the API (used for OAuth callbacks + absolute image URLs).
# Google redirect URI is ${BETTER_AUTH_URL}/api/auth/callback/google
BETTER_AUTH_URL="http://localhost:3001"

# Origins allowed to initiate/complete auth (comma-separated). The mobile scheme
# orbit:// is added automatically. Defaults cover localhost + prod hosts.
# CORS_ALLOWED_ORIGINS="http://localhost:8081,http://localhost:3001,https://www.myorbit360.com"

# -----------------
# Server (Optional)
# -----------------
# Port the API server runs on (default: 3001)
PORT=3001

# Node environment (development or production)
NODE_ENV=development

# -----------------
# AI Provider (Optional - controls which LLM provider the assistant uses)
# -----------------
# Options: "cerebras" (default), "google_structured", "finetuned"
AI_PROVIDER="cerebras"

# Override the default model for the chosen provider (optional)
# Defaults: cerebras → llama3.1-8b, google_structured → gemini-flash-lite-latest, finetuned → your-org/orbit-assistant-v1
# AI_MODEL="llama3.1-8b"

# -----------------
# Google Generative AI (Required for embeddings, required for assistant if AI_PROVIDER=google)
# -----------------
# API key for Gemini models (used by @ai-sdk/google)
# Get this from: https://aistudio.google.com/app/apikey
# Note: Always needed — embeddings use Gemini regardless of AI_PROVIDER
GOOGLE_GENERATIVE_AI_API_KEY="your-google-ai-api-key"

# -----------------
# Groq (Required if AI_PROVIDER=groq)
# -----------------
# API key for Groq inference (Llama models)
# Get this from: https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key"

# -----------------
# Google OAuth (Required — sign-in + Google Contacts import)
# -----------------
# Used by Better Auth for Google sign-in AND to refresh the Contacts import
# token. In Google Cloud Console → APIs & Services → Credentials, add the
# redirect URI ${BETTER_AUTH_URL}/api/auth/callback/google to this OAuth client.
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
