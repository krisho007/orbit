# ==============================================
# Orbit API Environment Variables
# ==============================================

# -----------------
# Database (Required)
# -----------------
# Your Supabase PostgreSQL connection string
# Get this from: Supabase Dashboard → Settings → Database → Connection String
# Use the "Connection pooling" URL for better performance
DATABASE_URL="postgresql://postgres.ghjqmkvsnwvppbpfnoii:Kc6swznz%40%401@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# -----------------
# Supabase Auth (Required)
# -----------------
# Used to verify JWT tokens from mobile/web clients
# Get these from: Supabase Dashboard → Settings → API

# Your Supabase project URL
SUPABASE_URL="https://ghjqmkvsnwvppbpfnoii.supabase.co"

# Supabase anonymous key (public, safe to expose)
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# -----------------
# Server (Optional)
# -----------------
# Port the API server runs on (default: 3001)
PORT=3001

# Node environment (development or production)
NODE_ENV=development

# -----------------
# AI Provider (Optional - controls which LLM provider the assistant uses)
# -----------------
# Options: "cerebras" (default), "google_structured", "finetuned"
AI_PROVIDER="cerebras"

# Override the default model for the chosen provider (optional)
# Defaults: cerebras → llama3.1-8b, google_structured → gemini-flash-lite-latest, finetuned → your-org/orbit-assistant-v1
# AI_MODEL="llama3.1-8b"

# -----------------
# Google Generative AI (Required for embeddings, required for assistant if AI_PROVIDER=google)
# -----------------
# API key for Gemini models (used by @ai-sdk/google)
# Get this from: https://aistudio.google.com/app/apikey
# Note: Always needed — embeddings use Gemini regardless of AI_PROVIDER
GOOGLE_GENERATIVE_AI_API_KEY="your-google-ai-api-key"

# -----------------
# Groq (Required if AI_PROVIDER=groq)
# -----------------
# API key for Groq inference (Llama models)
# Get this from: https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key"

# -----------------
# Google OAuth (Required for Google Contacts import token refresh)
# -----------------
# These are the same credentials configured in Supabase's Google OAuth provider settings
# Get these from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
