# ==============================================
# Orbit Web App Environment Variables
# ==============================================
# Note: Expo requires variables to be prefixed with EXPO_PUBLIC_
# to be accessible in the app.

# -----------------
# API URL
# -----------------
# Auth is Better Auth (Google), cookie-based and served by the API. No Supabase.
#
# In production (fly.io) the web app is served same-origin by the API, so leave
# this empty. In local dev, point it at the local API server.
EXPO_PUBLIC_API_URL="http://localhost:3001"

# For production (deployed to fly.io with the API), same origin:
# EXPO_PUBLIC_API_URL=""
