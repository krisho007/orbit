# ==============================================
# Orbit Mobile/Web Environment Variables.
# This is git tracked. DO NOT PUT ANYTHING HERE THAT IS NOT PUBLIC.
# ==============================================
# Note: Expo requires variables to be prefixed with EXPO_PUBLIC_
# to be accessible in the app

# -----------------
# Supabase (Required)
# -----------------
# Used for authentication and database access
# Get these from: Supabase Dashboard → Settings → API

# Your Supabase project URL
EXPO_PUBLIC_SUPABASE_URL="https://ghjqmkvsnwvppbpfnoii.supabase.co"

# Supabase anonymous key (public, safe to expose in mobile apps)
EXPO_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_wyT6ebepitJ3_4k1YvC8MQ_1Va3fmJb"

# -----------------
# API URL (Required for Development)
# -----------------
# In development: Point to local API server
# In production (fly.io): Leave empty or omit (uses same origin)

# For Development Build
# EXPO_PUBLIC_API_URL="http://192.168.1.9:3001"

# For local development
# EXPO_PUBLIC_API_URL="http://10.0.2.2:3001"

# For production (deployed to fly.io with API)
EXPO_PUBLIC_API_URL="https://orbit-app.fly.dev"

# For iOS simulator (if localhost doesn't work)
# EXPO_PUBLIC_API_URL="http://127.0.0.1:3001"

# For Android emulator (10.0.2.2 = host machine)
# EXPO_PUBLIC_API_URL="http://10.0.2.2:3001"
